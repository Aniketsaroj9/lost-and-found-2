# Copy to .env (same folder as this file) for local overrides, or set
# these as environment variables in your hosting platform (Railway/etc).
# NEVER commit a real .env file — it's already in .gitignore.

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=lost_and_found_2

# SMTP (for sending verification/notification emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-new-app-password
SMTP_FROM=noreply@lostandfound.com

# URL of the Python ML matching microservice (set this to wherever you
# deploy ml_service/, e.g. https://lost-found-ml.up.railway.app/match)
ML_SERVICE_URL=http://localhost:5000/match
